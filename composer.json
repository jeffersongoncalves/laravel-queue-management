{
    "name": "jeffersongoncalves/laravel-queue-management",
    "description": "Manage Laravel's database queue tables (jobs, failed_jobs, job_batches) through models and a service layer.",
    "keywords": [
        "laravel",
        "queue",
        "queue-management",
        "jobs",
        "failed-jobs",
        "job-batches"
    ],
    "homepage": "https://github.com/jeffersongoncalves/laravel-queue-management",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Jefferson Gonçalves",
            "email": "gerson.simao.92@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.14.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "JeffersonGoncalves\\QueueManagement\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\QueueManagement\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "JeffersonGoncalves\\QueueManagement\\QueueManagementServiceProvider"
            ],
            "aliases": {
                "QueueManagement": "JeffersonGoncalves\\QueueManagement\\Facades\\QueueManagement"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
